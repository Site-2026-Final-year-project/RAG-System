# --- Option A: Docker Postgres + pgvector (recommended) ---
#   docker compose up -d
#   Python: use psycopg URL on host port 5433 (see docker-compose.yml)
DATABASE_URL=postgresql+psycopg://postgres:root@localhost:5433/fyp
#
# Express/Prisma on the same DB (single DB): use same host/port/db, Prisma style, e.g.
#   DATABASE_URL="postgresql://postgres:root@localhost:5433/fyp?schema=public"
#
# --- Local Homebrew Postgres (no Docker) — only if you installed pgvector for that PG version ---
# DATABASE_URL=postgresql+psycopg://postgres:root@localhost:5432/fyp

# Option B split: RAG on Docker, Prisma tables still on another server — uncomment:
# PRISMA_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/your_prisma_db

RAG_KB_BACKEND=auto

# EXPRESS_PROJECT_ROOT=/path/to/driver-garage-backend

# JWT_SECRET=your-shared-secret
# JWT_ALGORITHM=HS256
